{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shore360.example/schemas/shore-sentinel/scanner-output.schema.json",
  "title": "Shore Sentinel scanner output",
  "type": "object",
  "required": ["contractVersion", "scanner", "target", "coverage", "decision", "findings", "collectedAt", "metadata", "score", "executive_summary"],
  "$defs": {
    "rfc3339": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?!(?!(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:[02468][048]|[13579][26])00)-02-29T)[0-9]{4}-02-29T)(?![0-9]{4}-(?:02-(?:30|31)|(?:04|06|09|11)-31))[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]([.][0-9]+)?(Z|[+-](0[0-9]|1[0-9]|2[0-3]):[0-5][0-9])$"
    },
    "scope": { "enum": ["target_source", "host_runtime", "external/unknown"] },
    "reachability": { "enum": ["unknown", "declared", "host_only", "host_observed"] },
    "evidenceKind": { "enum": ["observation", "secret_classification", "compose_socket_mount", "correlation", "coverage_diagnostic"] },
    "confidence": { "enum": ["confirmed", "high", "medium", "low"] },
    "status": { "enum": ["PASS", "WARN", "FAIL", "SKIP"] },
    "risk": { "enum": ["Critical", "High", "Medium", "Low", "Info"] },
    "severity": { "enum": ["informational", "low", "moderate", "high", "critical"] },
    "evidence": {
      "type": "object",
      "required": ["text", "kind", "scope", "confidence"],
      "properties": {
        "text": { "type": "string" },
        "kind": { "$ref": "#/$defs/evidenceKind" },
        "scope": { "$ref": "#/$defs/scope" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "coverageRecord": { "type": "object", "additionalProperties": true }
  },
  "properties": {
    "contractVersion": { "const": "shore-sentinel.scanner-output/v1" },
    "scanner": {
      "type": "object",
      "required": ["name", "version", "scriptSha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "scriptSha256": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["assetId"],
      "properties": {
        "assetId": { "type": "string", "minLength": 1 },
        "hostname": { "type": "string" },
        "ip": { "type": "string" },
        "subjectType": { "type": "string" }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": ["scan_complete"],
      "properties": {
        "requested_root": { "type": "string", "minLength": 1 },
        "effective_root": { "type": "string", "minLength": 1 },
        "scope_mode": { "type": "string", "enum": ["exact", "discover", "runtime", "full"] },
        "scan_complete": { "type": "boolean" },
        "security_relevant_incomplete": { "type": "boolean" },
        "files_discovered": { "type": "integer", "minimum": 0 },
        "truncated_file_list": { "type": "boolean" },
        "host_runtime_not_collected": { "type": "boolean" },
        "host_runtime_incomplete": { "type": "boolean" },
        "host_runtime_error": { "type": "string" },
        "secret_files_not_read": { "type": "array", "items": { "type": "string" } },
        "missing_optional_paths": { "type": "array", "items": { "type": "string" } },
        "symlink_directory_skips": { "type": "array", "items": { "type": "string" } },
        "symlink_skips": { "type": "array", "items": { "type": "string" } },
        "walk_errors": { "type": "array", "items": { "$ref": "#/$defs/coverageRecord" } },
        "unreadable_paths": { "type": "array", "items": { "$ref": "#/$defs/coverageRecord" } },
        "truncated_files": { "type": "array", "items": { "$ref": "#/$defs/coverageRecord" } },
        "limit_overrides": { "type": "array", "items": { "$ref": "#/$defs/coverageRecord" } },
        "config_parse_errors": { "type": "array", "items": { "$ref": "#/$defs/coverageRecord" } },
        "scope_errors": { "type": "array", "items": { "$ref": "#/$defs/coverageRecord" } },
        "decode_errors": { "type": "array", "items": { "type": "string" } },
        "runtime_probe_errors": { "type": "array", "items": { "$ref": "#/$defs/coverageRecord" } }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["status", "exit_code"],
      "properties": {
        "status": { "enum": ["PASS", "ERROR", "FAIL"] },
        "exit_code": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "severityScore", "category", "description", "evidence", "status", "risk", "scope", "confidence", "reachability", "evidenceKind", "derived", "derivedFrom"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "severity": { "$ref": "#/$defs/severity" },
          "severityScore": { "type": "integer", "minimum": 0 },
          "category": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
          "remediation": { "type": ["string", "null"] },
          "references": { "type": "array", "items": { "type": "string" } },
          "cve": { "type": ["string", "null"] },
          "cveUrl": { "type": ["string", "null"] },
          "cves": { "type": "array", "items": { "type": "string" } },
          "status": { "$ref": "#/$defs/status" },
          "risk": { "$ref": "#/$defs/risk" },
          "check": { "type": "string" },
          "scope": { "$ref": "#/$defs/scope" },
          "confidence": { "$ref": "#/$defs/confidence" },
          "reachability": { "$ref": "#/$defs/reachability" },
          "evidenceKind": { "$ref": "#/$defs/evidenceKind" },
          "derived": { "type": "boolean" },
          "derivedFrom": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "source": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "collectedAt": { "$ref": "#/$defs/rfc3339" },
    "metadata": {
      "type": "object",
      "required": ["generated_utc", "script_version", "script_sha256", "target_asset_id", "coverage"],
      "properties": {
        "generated_utc": { "$ref": "#/$defs/rfc3339" },
        "script_version": { "type": "string", "minLength": 1 },
        "script_sha256": { "type": "string", "minLength": 1 },
        "target_asset_id": { "type": "string", "minLength": 1 },
        "coverage": { "$ref": "#/properties/coverage" }
      },
      "additionalProperties": true
    },
    "score": {
      "type": "object",
      "required": ["overall_score", "grade", "categories"],
      "properties": {
        "overall_score": { "type": "number" },
        "grade": { "type": "string" },
        "categories": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "executive_summary": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
