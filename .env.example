# Shore Sentinel environment example
# Copy to .env for local development and replace every replace-me value before use.
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_API_URL=http://localhost:4000
SHORE_SENTINEL_APP_URL=http://localhost:3010
SHORE_SENTINEL_API_URL=http://localhost:4000
API_URL=http://localhost:4000
WEB_PORT=3010
API_PORT=4000
POSTGRES_DB=shore_sentinel
POSTGRES_USER=shore_sentinel
POSTGRES_PASSWORD=replace-me-postgres-password
DATABASE_URL=postgresql://shore_sentinel:${POSTGRES_PASSWORD:-replace-me-postgres-password}@postgres:5432/shore_sentinel
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=shore-sentinel-artifacts
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=replace-me-minio-access
MINIO_SECRET_KEY=replace-me-minio-secret
SEED_ADMIN_PASSWORD=replace-me-seed-admin-password
SHORE_SENTINEL_SECRET_KEY=replace-me-32-byte-application-secret
SESSION_COOKIE_SECRET=replace-me-session-cookie-secret
SMTP_HOST=replace-me-smtp-host
SMTP_PORT=587
SMTP_USERNAME=replace-me-smtp-username
SMTP_PASSWORD=replace-me-smtp-password
SMTP_FROM=shore-sentinel@shore360.local
SMTP_ENCRYPTION=starttls
SMTP_TLS=true
FEATURE_ONE_TIME_AUDIT=true
FEATURE_MANAGED_MACHINES=true
FEATURE_KNOWLEDGEBASE=true
FEATURE_MANAGED_MACHINE_SCHEDULES=true
FEATURE_COMPARISON_ANALYTICS=true
FEATURE_IMPORT_EXPORT_REPORTS=true
FEATURE_REMEDIATION_WORKFLOWS=true
FEATURE_AGENT_PULL_MODE=true
FEATURE_CENTRAL_DASHBOARD=true
FEATURE_LOGS_PAGE=true
